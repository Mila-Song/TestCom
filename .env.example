# Flask session secret (must be long random string in production)
APP_SECRET_KEY=replace-with-long-random-secret

# Optional: host/port for local run
APP_HOST=127.0.0.1
APP_PORT=8090
FLASK_DEBUG=0

# Optional: primary admin credentials (recommended for production)
# PRIMARY_ADMIN_PASSWORD_HASH takes precedence over PRIMARY_ADMIN_PASSWORD
PRIMARY_ADMIN_PASSWORD=
PRIMARY_ADMIN_PASSWORD_HASH=

# Optional: Qwen/DashScope API
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com
QWEN_IMAGE_MODEL=qwen-image-2.0-2026-03-03
QWEN_IMAGE_EDIT_MODEL=qwen-image-2.0-pro

# Optional upload limit (bytes), default 25MB
PDD_MAX_CONTENT_LENGTH=26214400
